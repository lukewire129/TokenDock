<Window x:Class="TokenDock.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:TokenDock"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"        
        MinWidth="900"
        MinHeight="750"
        SizeToContent="WidthAndHeight"
        Background="#F4F5F7"
        ExtendClientAreaToDecorationsHint="True"
        Icon="/Assets/AppIcon.ico"
        Title=" "
        x:DataType="local:MainViewModel"
        d:DesignHeight="750"
        d:DesignWidth="1040"
        mc:Ignorable="d">
    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type local:CodexDashboardViewModel}">
            <local:CodexDashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:ClaudeDashboardViewModel}">
            <local:ClaudeDashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:SettingsViewModel}">
            <local:SettingsView />
        </DataTemplate>
    </Window.DataTemplates>

    <Window.Styles>
        <Style Selector="TextBlock.title">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.metric">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontSize" Value="34" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style Selector="Border.sidebarCard">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style Selector="ProgressBar">
            <Setter Property="Height" Value="9" />
            <Setter Property="CornerRadius" Value="99" />
            <Setter Property="Background" Value="#E5E7EB" />
            <Setter Property="Foreground" Value="#10A37F" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#111827" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,9" />
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style Selector="Button.navTab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#4B5563" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,8" />
        </Style>

        <Style Selector="Button.navTab:pointerover">
            <Setter Property="Background" Value="#EEF2F7" />
            <Setter Property="Foreground" Value="#111827" />
        </Style>

        <Style Selector="Button.chrome">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="Button.chrome:pointerover">
            <Setter Property="Background" Value="#F3F4F6" />
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>

        <Style Selector="Button.chrome.close:pointerover">
            <Setter Property="Background" Value="#FEE2E2" />
            <Setter Property="Foreground" Value="#991B1B" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="24,10,200,10" ColumnSpacing="12">
            <Border Background="#FFFFFF"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="999"
                    Padding="4"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button Classes="navTab" Command="{Binding ShowDashboard}" Content="현황" />
                    <Button Classes="navTab" Command="{Binding ShowSettings}" Content="설정" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="#EEF2F7"
                    CornerRadius="999"
                    Padding="4"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button Name="CodexDashboardButton" Classes="navTab" Command="{Binding ShowCodexDashboard}" Content="Codex" />
                    <Button Name="ClaudeDashboardButton" Classes="navTab" Command="{Binding ShowClaudeDashboard}" Content="Claude" />
                </StackPanel>
            </Border>

            <TextBlock Grid.Column="2"
                       Foreground="#6B7280"
                       FontSize="13"
                       Text="usage monitor"
                       VerticalAlignment="Center" />

            <Button Grid.Column="3" Classes="secondary" Click="Refresh_OnClick" Content="새로고침" />

        </Grid>

        <Border Name="ToastHost"
                x:DataType="local:CodexDashboardViewModel"
                Grid.RowSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,78,24,0"
                ZIndex="10"
                Padding="14,10"
                MaxWidth="420"
                Background="{Binding Toast.Background}"
                BorderBrush="{Binding Toast.BorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                BoxShadow="0 10 24 0 #22000000"
                IsVisible="{Binding Toast.IsVisible}">
            <TextBlock Foreground="{Binding Toast.Foreground}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Text="{Binding Toast.Message}"
                       TextWrapping="Wrap" />
        </Border>

        <TransitioningContentControl Name="PageHost" Grid.Row="1" Margin="24,8,24,24">
            <TransitioningContentControl.PageTransition>
                <CrossFade Duration="0:0:0.18" />
            </TransitioningContentControl.PageTransition>
        </TransitioningContentControl>
    </Grid>
</Window>
