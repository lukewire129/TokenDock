<Window x:Class="TokenDock.TaskbarBandWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="220"
        Height="40"
        Background="Transparent"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Topmost="True"
        TransparencyLevelHint="Transparent"
        Title="TokenDock Taskbar Band">
    <Border Name="BandRoot"
            Height="40"
            Padding="10,3"
            CornerRadius="10"
            PointerPressed="BandRoot_OnPointerPressed">
        <StackPanel Spacing="2" VerticalAlignment="Center">
            <Grid Name="CodexRow" ColumnDefinitions="Auto,*" ColumnSpacing="7">
                <Ellipse Width="7" Height="7" Fill="#10A37F" VerticalAlignment="Center" />
                <Grid Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <TextBlock Name="CodexNameText" FontSize="11" FontWeight="SemiBold" Text="Codex" />
                    <TextBlock Name="CodexUsageText" Grid.Column="1" FontSize="11" FontWeight="Normal" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" HorizontalAlignment="Right"/>
                </Grid>
            </Grid>
            <Grid Name="ClaudeRow" ColumnDefinitions="Auto,*" ColumnSpacing="7">
                <Ellipse Width="7" Height="7" Fill="#D97706" VerticalAlignment="Center" />
                <Grid Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <TextBlock Name="ClaudeNameText" FontSize="11" FontWeight="SemiBold" Text="Claude" />
                    <TextBlock Name="ClaudeUsageText" Grid.Column="1" FontSize="11" FontWeight="Normal" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" HorizontalAlignment="Right"/>
                </Grid>
            </Grid>
        </StackPanel>
    </Border>
</Window>
